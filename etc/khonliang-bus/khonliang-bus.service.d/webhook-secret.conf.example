# systemd drop-in: feed GITHUB_WEBHOOK_SECRET into the khonliang-bus unit.
#
# Install path:
#   /etc/systemd/system/khonliang-bus.service.d/webhook-secret.conf
#   owned by root:root, mode 0644
#
# After installing (and after editing /etc/khonliang/webhook-secret.env to
# carry the real secret), reload + restart:
#
#   sudo systemctl daemon-reload
#   sudo systemctl restart khonliang-bus.service
#
# Verify the bus picked the secret up — the webhook endpoint should now
# return 401 (signature missing) on an unsigned POST instead of 503
# (no secret configured). The port below assumes the canonical
# systemd-unit override of ``--port 8788``; the bare ``python3 -m bus``
# default is 8787, so substitute if your ExecStart doesn't pass --port:
#
#   curl -X POST http://localhost:8788/v1/webhooks/github \
#     -H 'X-GitHub-Event: ping' -d '{"zen":"smoke"}' \
#     -w '\nHTTP %{http_code}\n'
#
# Note the ``-`` prefix on ``EnvironmentFile=`` below: it tells systemd
# the file is OPTIONAL — if it is missing or transiently unreadable the
# unit still starts, and the bus's own 503-when-no-secret path handles
# the missing-config case. WITHOUT the leading ``-`` systemd refuses to
# start the unit at all on a missing env file, turning a webhook-only
# configuration problem into a full bus outage.

[Service]
EnvironmentFile=-/etc/khonliang/webhook-secret.env
